<div class="chat-show">
  <div class="chats-index-header">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item">
          <%= link_to chats_path do %>
            <i class="fa-solid fa-house me-1"></i> Home
          <% end %>
        </li>
        <li class="breadcrumb-item active"><%= @chat.title %></li>
      </ol>
    </nav>
  </div>

  <div class="chat-show-body">
    <h2 class="chat-show-title"><%= @chat.title %></h2>
    <p class="chat-show-empty">No messages yet. Start the conversation below.</p>
  </div>
</div>

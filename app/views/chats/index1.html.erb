<div class="chats-index">
  <div class="chats-index-header">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item active">
          <i class="fa-solid fa-house me-1"></i> Home
        </li>
      </ol>
    </nav>
    <%= link_to new_chat_path, class: "btn btn-new" do %>
      <i class="fa-solid fa-plus"></i> New
    <% end %>
  </div>

  <div class="chats-hero">
    <h1>What are you making sense of today?</h1>

    <%= link_to new_chat_path, class: "hero-input-card" do %>
      <div class="hero-input-placeholder">
        <i class="fa-solid fa-magnifying-glass"></i>
        <span>Start a new analysis...</span>
      </div>
      <div class="hero-input-footer">
        <span class="hero-ask-btn">
          <i class="fa-solid fa-wand-magic-sparkles"></i> Ask
        </span>
      </div>
    <% end %>
  </div>

  <div class="suggestion-grid">
    <%= link_to new_chat_path, class: "suggestion-card" do %>
      <div class="suggestion-icon">
        <i class="fa-solid fa-chart-bar"></i>
      </div>
      <h3>Competitive Landscape Research</h3>
      <p>Analyze market positioning and competitor strategies</p>
    <% end %>

    <%= link_to new_chat_path, class: "suggestion-card" do %>
      <div class="suggestion-icon">
        <i class="fa-solid fa-arrow-trend-up"></i>
      </div>
      <h3>Emerging Consumer Trend Direction</h3>
      <p>Identify and track emerging market trends</p>
    <% end %>

    <%= link_to new_chat_path, class: "suggestion-card" do %>
      <div class="suggestion-icon">
        <i class="fa-solid fa-bullseye"></i>
      </div>
      <h3>Market Size & Opportunity Assessment</h3>
      <p>Evaluate market potential and opportunities</p>
    <% end %>

    <%= link_to new_chat_path, class: "suggestion-card" do %>
      <div class="suggestion-icon">
        <i class="fa-solid fa-users"></i>
      </div>
      <h3>Demographic Segment Breakdown</h3>
      <p>Understand your target audience segments</p>
    <% end %>
  </div>
</div>

<div class="chats-new">
  <div class="chats-index-header">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item">
          <%= link_to chats_path do %>
            <i class="fa-solid fa-house me-1"></i> Home
          <% end %>
        </li>
        <li class="breadcrumb-item active">New analysis</li>
      </ol>
    </nav>
  </div>

  <div class="chats-hero">
    <h1>What do you want to analyse?</h1>

    <%= simple_form_for @chat do |f| %>
      <div class="hero-form-card">
        <%= f.input :title,
            label: false,
            placeholder: "e.g. Nike running shoes on social media...",
            input_html: { class: "hero-form-input", autofocus: true } %>
        <div class="hero-form-footer">
          <%= f.submit "Ask", class: "hero-ask-btn" %>
        </div>
      </div>
    <% end %>
  </div>
</div>

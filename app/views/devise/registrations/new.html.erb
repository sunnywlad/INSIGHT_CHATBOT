<div class="auth-page">
  <div class="auth-card">
    <div class="auth-header">
      <span class="landing-logo-icon">IB</span>
      <h2>Create your account</h2>
      <p>Start analyzing social media insights</p>
    </div>

    <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= f.error_notification %>

      <div class="auth-fields">
        <%= f.input :email,
                    required: true,
                    autofocus: true,
                    label: false,
                    placeholder: "Email address",
                    input_html: { autocomplete: "email", class: "auth-input" } %>
        <%= f.input :password,
                    required: true,
                    label: false,
                    placeholder: "Password (6 characters minimum)",
                    hint: false,
                    input_html: { autocomplete: "new-password", class: "auth-input" } %>
        <%= f.input :password_confirmation,
                    required: true,
                    label: false,
                    placeholder: "Confirm password",
                    input_html: { autocomplete: "new-password", class: "auth-input" } %>
      </div>

      <div class="auth-actions">
        <%= f.button :submit, "Sign up", class: "landing-btn landing-btn-primary auth-submit" %>
      </div>
    <% end %>

    <div class="auth-footer">
      <p>Already have an account? <%= link_to "Sign in", new_user_session_path %></p>
    </div>
  </div>
</div>

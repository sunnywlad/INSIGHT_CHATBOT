<div class="landing">
  <!-- Ambient glow -->
  <div class="landing-glow"></div>
  <div class="landing-grain"></div>

  <!-- Nav -->
  <nav class="landing-nav">
    <div class="landing-nav-logo">
      <span class="landing-logo-icon">IB</span>
      <span class="landing-logo-text">InsightsBot</span>
    </div>
    <div class="landing-nav-links">
      <%= link_to "Sign in", new_user_session_path, class: "landing-nav-link" %>
      <%= link_to "Get started", new_user_registration_path, class: "landing-btn landing-btn-accent" %>
    </div>
  </nav>

  <!-- Hero -->
  <section class="landing-hero">
    <div class="landing-badge">
      <i class="fa-solid fa-bolt"></i>
      <span>Real-time social listening powered by AI</span>
    </div>

    <h1 class="landing-title">
      Decode the <em>voice</em><br>of social media
    </h1>

    <p class="landing-subtitle">
      Ask any question. InsightsBot scans millions of conversations across Reddit, X, Instagram and TikTok to deliver actionable consumer insights in seconds.
    </p>

    <div class="landing-ctas">
      <%= link_to new_user_registration_path, class: "landing-btn landing-btn-primary" do %>
        Start analyzing — free <i class="fa-solid fa-arrow-right"></i>
      <% end %>
      <%= link_to new_user_session_path, class: "landing-btn landing-btn-secondary" do %>
        <i class="fa-solid fa-play"></i> See how it works
      <% end %>
    </div>

    <!-- Floating preview cards -->
    <div class="landing-preview">
      <div class="preview-card preview-card-main">
        <div class="preview-card-header">
          <div class="preview-dot preview-dot-green"></div>
          <span>InsightsBot</span>
        </div>
        <div class="preview-prompt">
          <i class="fa-solid fa-magnifying-glass"></i>
          <span>What do Gen Z consumers think about sustainable fashion?</span>
        </div>
        <div class="preview-result">
          <div class="preview-result-bar">
            <div class="preview-bar-fill" style="width: 78%"></div>
          </div>
          <div class="preview-result-labels">
            <span class="preview-label-positive"><i class="fa-solid fa-arrow-trend-up"></i> 78% positive</span>
            <span class="preview-label-mentions">12.4k mentions</span>
          </div>
        </div>
      </div>

      <div class="preview-card preview-card-float preview-card-reddit">
        <div class="preview-card-icon"><i class="fa-brands fa-reddit-alien"></i></div>
        <div class="preview-card-stat">
          <span class="stat-number">4.2k</span>
          <span class="stat-label">threads analyzed</span>
        </div>
      </div>

      <div class="preview-card preview-card-float preview-card-twitter">
        <div class="preview-card-icon"><i class="fa-brands fa-x-twitter"></i></div>
        <div class="preview-card-stat">
          <span class="stat-number">8.1k</span>
          <span class="stat-label">posts scanned</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Features strip -->
  <section class="landing-features">
    <div class="landing-features-grid">
      <div class="feature-item">
        <div class="feature-icon"><i class="fa-solid fa-comments"></i></div>
        <h3>Natural language queries</h3>
        <p>Ask questions like you'd ask a colleague. No complex filters or boolean operators.</p>
      </div>
      <div class="feature-item">
        <div class="feature-icon"><i class="fa-solid fa-chart-line"></i></div>
        <h3>Sentiment analysis</h3>
        <p>Understand how people feel about brands, products, and trends across platforms.</p>
      </div>
      <div class="feature-item">
        <div class="feature-icon"><i class="fa-solid fa-layer-group"></i></div>
        <h3>Multi-platform coverage</h3>
        <p>Reddit, X, Instagram, TikTok — aggregated into one unified insight stream.</p>
      </div>
      <div class="feature-item">
        <div class="feature-icon"><i class="fa-solid fa-bolt"></i></div>
        <h3>Instant insights</h3>
        <p>From question to actionable answer in seconds, not hours of manual research.</p>
      </div>
    </div>
  </section>

  <!-- Social proof -->
  <section class="landing-proof">
    <p class="proof-text">Trusted by product teams, marketers, and researchers to decode consumer conversations.</p>
    <div class="proof-platforms">
      <span><i class="fa-brands fa-reddit-alien"></i> Reddit</span>
      <span><i class="fa-brands fa-x-twitter"></i> X</span>
      <span><i class="fa-brands fa-instagram"></i> Instagram</span>
      <span><i class="fa-brands fa-tiktok"></i> TikTok</span>
    </div>
  </section>

  <!-- Footer CTA -->
  <section class="landing-footer-cta">
    <h2>Ready to listen?</h2>
    <p>Start understanding what your audience really thinks.</p>
    <%= link_to new_user_registration_path, class: "landing-btn landing-btn-primary" do %>
      Get started for free <i class="fa-solid fa-arrow-right"></i>
    <% end %>
  </section>

  <footer class="landing-footer">
    <span>&copy; 2026 InsightsBot</span>
  </footer>
</div>

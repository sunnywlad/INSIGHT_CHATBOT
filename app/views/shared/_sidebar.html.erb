<aside class="sidebar">
  <div class="sidebar-header">
    <span class="sidebar-logo">IB</span>
    <span class="sidebar-brand">InsightsBot</span>
  </div>

  <nav class="sidebar-nav">
    <%= link_to products_path, class: "sidebar-link #{current_page?(products_path) ? 'active' : ''}" do %>
      <i class="fa-solid fa-house"></i>
      <span>Home</span>
    <% end %>

    <div class="sidebar-section-title">My products</div>

    <% if current_user.products.any? %>
      <% current_user.products.distinct.order(created_at: :desc).limit(10).each do |product| %>
        <div class="sidebar-product-row">
          <%= link_to product_path(product), class: "sidebar-link sidebar-product-link #{current_page?(product_path(product)) ? 'active' : ''}" do %>
            <span><%= truncate(product.name, length: 28) %></span>
          <% end %>
          <%= button_to product_path(product), method: :delete,
              data: { turbo_confirm: "Do you really want to delete this product?" },
              class: "btn-delete-product" do %>
            <i class="fa-solid fa-xmark"></i>
          <% end %>
        </div>
      <% end %>
    <% end %>

    <%= link_to new_product_path, class: "sidebar-new-btn" do %>
      <i class="fa-solid fa-plus"></i>
      <span>New product</span>
    <% end %>
  </nav>

  <div class="sidebar-footer">
    <div class="sidebar-user">
      <i class="fa-regular fa-user"></i>
      <span><%= current_user.email %></span>
    </div>
    <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "sidebar-link sidebar-logout" do %>
      <i class="fa-solid fa-right-from-bracket"></i>
      <span>Sign out</span>
    <% end %>
  </div>
</aside>

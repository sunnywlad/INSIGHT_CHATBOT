<div class="chats-new">
  <div class="chats-index-header">
    <nav class="breadcrumb">
      <%= link_to "Home", products_path, class: "breadcrumb-item" %>
      <span class="breadcrumb-item active">New product</span>
    </nav>
  </div>

  <div class="chats-hero">
    <h1>Add a new product to analyze</h1>

    <div class="hero-form-card">
      <%= simple_form_for @product do |f| %>
        <div class="form-group">
          <%= f.input :name, input_html: { class: "hero-form-input", placeholder: "Product name..." }, label: false %>
        </div>
        <div class="form-group">
          <%= f.input :brand, input_html: { class: "hero-form-input", placeholder: "Brand name..." }, label: false %>
        </div>
        <div class="hero-form-footer">
          <%= f.submit "Create product", class: "hero-ask-btn" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

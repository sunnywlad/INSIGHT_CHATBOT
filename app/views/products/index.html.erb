<div class="chats-index">
  <div class="chats-index-header">
    <nav class="breadcrumb">
      <span class="breadcrumb-item active">
        <i class="fa-solid fa-house"></i> Home
      </span>
    </nav>
    <%= link_to new_product_path, class: "btn-new" do %>
      <i class="fa-solid fa-plus"></i> New product
    <% end %>
  </div>

  <div class="chats-hero">
    <h1>What are you making sense of today?</h1>

    <%= link_to new_product_path, class: "hero-input-card" do %>
      <div class="hero-input-placeholder">
        <i class="fa-solid fa-magnifying-glass"></i>
        <span>Add a product to analyze...</span>
      </div>
      <div class="hero-input-footer">
        <span class="hero-ask-btn">
          <i class="fa-solid fa-wand-magic-sparkles"></i> Analyze
        </span>
      </div>
    <% end %>
  </div>

  <div class="suggestion-grid">
    <% if current_user.products.any? %>
      <% current_user.products.each do |product| %>
        <div class="suggestion-card-wrapper">
          <%= link_to product_path(product), class: "suggestion-card" do %>
            <div class="suggestion-icon">
              <i class="fa-solid fa-box"></i>
            </div>
            <h3><%= product.name %></h3>
            <p><%= product.brand %></p>
          <% end %>
          <%= button_to product_path(product), method: :delete,
              data: { turbo_confirm: "Do you really want to delete this product ?" },
              class: "btn-delete-product" do %>
            <i class="fa-solid fa-xmark"></i>
          <% end %>
        </div>
      <% end %>
    <% end %>

    <%= link_to new_product_path, class: "suggestion-card" do %>
      <div class="suggestion-icon">
        <i class="fa-solid fa-plus"></i>
      </div>
      <h3>Add Product</h3>
    <% end %>
  </div>
</div>
